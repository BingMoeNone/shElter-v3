# Database Configuration
DATABASE_URL=sqlite:///./wiki_platform.db

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration - Allowed frontend origins (JSON format)
# Development Environment
CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080","http://127.0.0.1:5500","http://localhost:5173","http://localhost:3000"]

# Debug Mode
DEBUG=True

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=True
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_DEFAULT=60/minute
